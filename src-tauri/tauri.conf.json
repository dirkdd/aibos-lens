{
  "productName": "AI-BOS Lens",
  "version": "0.1.0",
  "identifier": "ai.wildlife.aibos-lens",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "AI-BOS Lens",
        "width": 320,
        "height": 480,
        "alwaysOnTop": true,
        "decorations": false,
        "transparent": true,
        "resizable": true,
        "minWidth": 280,
        "minHeight": 320,
        "x": 50,
        "y": 50
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
