# AI-BOS Lens — Environment Variables
# Copy to .env and fill in your values

# ─── Deepgram (local STT) ─────────────────────────────────
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# ─── Fireflies (live meeting integration) ─────────────────
FIREFLIES_API_KEY=your_fireflies_api_key_here
FIREFLIES_GRAPHQL_URL=https://api.fireflies.ai/graphql
FIREFLIES_REALTIME_WS=wss://api.fireflies.ai

# ─── OpenClaw / Pi Agent ──────────────────────────────────
# Remote gateway (production)
OPENCLAW_WS_URL=wss://your-openclaw-gateway.ts.net
OPENCLAW_GATEWAY_TOKEN=your_gateway_token_here

# Local gateway (development)
OPENCLAW_LOCAL_URL=ws://localhost:18789

# ─── App Config ───────────────────────────────────────────
# Analysis cycle interval in seconds (default: 30)
ANALYSIS_INTERVAL_SECONDS=30

# Context window for analysis (seconds of transcript to send)
CONTEXT_WINDOW_SECONDS=60

# Model for entity detection (cheap + fast)
ANALYSIS_MODEL=claude-haiku-4-5

# ─── Development ──────────────────────────────────────────
NODE_ENV=development
VITE_DEV_SERVER_PORT=5173

# ─── Vite-exposed variables (frontend access) ─────────────
# Vite only exposes env vars prefixed with VITE_
VITE_DEEPGRAM_API_KEY=${DEEPGRAM_API_KEY}
VITE_FIREFLIES_API_KEY=${FIREFLIES_API_KEY}
VITE_FIREFLIES_GRAPHQL_URL=${FIREFLIES_GRAPHQL_URL}
VITE_OPENCLAW_WS_URL=${OPENCLAW_WS_URL}
VITE_OPENCLAW_GATEWAY_TOKEN=${OPENCLAW_GATEWAY_TOKEN}
VITE_ANALYSIS_INTERVAL_SECONDS=${ANALYSIS_INTERVAL_SECONDS}
VITE_CONTEXT_WINDOW_SECONDS=${CONTEXT_WINDOW_SECONDS}
